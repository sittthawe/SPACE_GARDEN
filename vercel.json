{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "api/vercel.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "server.js",
          "storage.js",
          "database.js"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/vercel.js?path=$1"
    }
  ]
}
